# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node (conformance runner, lint tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json.bak

# Python (conformance runner, tooling)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env
.env.local
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Rust (optional tooling)
target/
Cargo.lock

# Build artefacts
dist/
build/
out/
*.tgz

# Generated docs
site/
_site/
.docusaurus/
.cache/

# Generated CBOR fixtures (must be regenerated from JSON source)
**/*.cbor.generated

# Key material — NEVER commit
*.pem
*.key
*.crt
*.p12
*.pfx
private/
secrets/

# Local conformance runs
conformance/runner/results/
conformance/runner/.cache/

# Coverage
coverage/
.coverage
*.lcov
